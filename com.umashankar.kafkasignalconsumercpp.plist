<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd service for bt_signal_consumer -- the C++ port of
  ~/BazaarTalks/kafka_signal_consumer.py (see docs/MIGRATION_PLAN.md, Phase 7 /
  Cutover run #3). Runs alongside the Python original in a DISTINCT consumer
  group (--group-id kafka-signal-consumer-cpp) so the two don't split
  scan.signals's partitions between them.

  Install / reload:
    cp com.umashankar.kafkasignalconsumercpp.plist ~/Library/LaunchAgents/
    launchctl bootout   gui/$(id -u)/com.umashankar.kafkasignalconsumercpp 2>/dev/null
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.umashankar.kafkasignalconsumercpp.plist

  Status / logs:
    launchctl print gui/$(id -u)/com.umashankar.kafkasignalconsumercpp
    tail -f ~/BazaarTalks-cpp/logs/bt_signal_consumer.log

  NOTE (2026-07-12): switched from build/debug/ to build/release/ -- see
  com.umashankar.kafkacdcconsumercpp.plist's identical note for why.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.umashankar.kafkasignalconsumercpp</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/umashankar/BazaarTalks-cpp/build/release/services/stream_consumers/signal_consumer/bt_signal_consumer</string>
    <string>--window</string>
    <string>5</string>
    <string>--group-id</string>
    <string>kafka-signal-consumer-cpp</string>
  </array>
  <key>WorkingDirectory</key><string>/Users/umashankar/BazaarTalks-cpp</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/Users/umashankar/BazaarTalks-cpp/logs/bt_signal_consumer.log</string>
  <key>StandardErrorPath</key><string>/Users/umashankar/BazaarTalks-cpp/logs/bt_signal_consumer.err.log</string>
</dict>
</plist>
